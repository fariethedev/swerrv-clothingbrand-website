{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "swerrv/Dockerfile"
  },
  "deploy": {
    "startCommand": "java -jar -Dspring.profiles.active=docker swerrv/app.jar",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
